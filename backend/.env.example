# App
APP_ENV=development
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Database (Supabase)
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/postgres
DATABASE_URL_TEST=postgresql+asyncpg://USER:PASS@HOST:5432/postgres_test

# Redis (Upstash)
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

# Zafronix API (free tier: zwc_free_*; Pro+: zwc_pk_*)
ZAFRONIX_API_KEY=your_key_here
ZAFRONIX_API_BASE_URL=https://api.zafronix.com/fifa/worldcup/v1
ZAFRONIX_TOURNAMENT_YEAR=2026   # optional, default 2026

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# Scheduler tuning
POLL_INTERVAL_LIVE_SEC=30
POLL_INTERVAL_IDLE_SEC=300
FIXTURE_SYNC_INTERVAL_HOURS=6